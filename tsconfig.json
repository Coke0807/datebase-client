{
    "compilerOptions": {
        "module": "commonjs",
        "target": "ES2020",
        "rootDir": "./src",
        "outDir": "out",
        "lib": [
            "ES2020",
            "ES2022"
        ],
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "sourceMap": true,
        "paths": {
            "@/*": [
                "./src/*"
            ]
        },
        "skipLibCheck": true,
        "strict": false,
        "forceConsistentCasingInFileNames": true
    },
    "exclude": [
        "node_modules",
        ".vscode-test"
    ]
}